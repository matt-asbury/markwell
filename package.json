{
  "name": "markwell",
  "version": "1.1.0",
  "description": "Read Markdown well — a minimal Markdown and .mmd reader for macOS (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/build-icon.js && electron-builder --mac",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test test/slugify.test.js test/store.test.js test/ipc-handlers.test.js test/active-file-watcher.test.js test/renderer-helpers.test.js test/reader-dom.test.js test/markdown-render.test.js",
    "ci": "npm run lint && npm run format:check && npm test"
  },
  "author": "Markwell Contributors",
  "license": "MIT",
  "devDependencies": {
    "electron": "~33.0.0",
    "electron-builder": "~25.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "~25.0.0",
    "prettier": "^3.8.1",
    "sharp": "~0.33.5"
  },
  "dependencies": {
    "marked": "~15.0.0",
    "marked-footnote": "~1.4.0"
  },
  "build": {
    "appId": "com.markwell.app",
    "productName": "Markwell",
    "publish": null,
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mmd"
        ],
        "name": "Markdown document",
        "role": "Viewer",
        "mimeType": "text/markdown"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png"
    }
  }
}
